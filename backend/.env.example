# Backend-only .env.example (for running backend without Docker Compose)
# For Docker Compose use the ROOT .env.example instead.

APP_ENV=development
DEBUG=true
DOCS_URL=/docs
SECRET_KEY=REPLACE_WITH_python3_c_import_secrets_print_secrets_token_hex_32

# JSON array format required
ALLOWED_ORIGINS=["http://localhost:3000"]

# For local dev (not Docker): use localhost
DATABASE_URL=postgresql+asyncpg://churnguard:churnguard@localhost:5432/churnguard
SYNC_DATABASE_URL=postgresql+psycopg2://churnguard:churnguard@localhost:5432/churnguard
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

MODEL_PATH=app/ml/artifacts/v1.pkl
MIN_AUC_THRESHOLD=0.75
PREDICTION_BATCH_SIZE=500
CHUNK_SIZE=1000

UPLOAD_DIR=/tmp/churnguard/uploads
MAX_UPLOAD_SIZE_MB=50
LOG_LEVEL=INFO
