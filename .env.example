# ── HOW TO USE ────────────────────────────────────────────────────────────────
# 1. Copy:  cp .env.example .env
# 2. Generate SECRET_KEY:  python3 -c "import secrets; print(secrets.token_hex(32))"
# 3. Paste the output as SECRET_KEY below
# 4. Run:   docker compose up --build

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
DOCS_URL=/docs
SECRET_KEY=REPLACE_WITH_OUTPUT_OF_python3_c_import_secrets_print_secrets_token_hex_32

# ── CORS ──────────────────────────────────────────────────────────────────────
# Must be valid JSON array. Add your Vercel/Railway URL here for production.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Database (uses Docker service name 'postgres') ────────────────────────────
DATABASE_URL=postgresql+asyncpg://churnguard:churnguard@postgres:5432/churnguard
SYNC_DATABASE_URL=postgresql+psycopg2://churnguard:churnguard@postgres:5432/churnguard
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis (uses Docker service name 'redis') ──────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── ML ────────────────────────────────────────────────────────────────────────
MODEL_PATH=app/ml/artifacts/v1.pkl
MIN_AUC_THRESHOLD=0.75
PREDICTION_BATCH_SIZE=500
CHUNK_SIZE=1000

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/churnguard/uploads
MAX_UPLOAD_SIZE_MB=50

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
